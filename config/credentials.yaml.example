# config/credentials.yaml
# ─────────────────────────────────────────────────────────
# Sensitive credentials for the patrol robot.
# DO NOT commit this file to version control.
# Add credentials.yaml to your .gitignore.
# ─────────────────────────────────────────────────────────

glowforge:
  email:    'your_glowforge_email@example.com'
  password: 'your_glowforge_password'

gmail:
  sender_email:    'your_gmail@gmail.com'
  sender_password: 'your_16_char_app_password'   # Gmail App Password (not your login password)
  recipient_email: 'recipient@uw.edu'